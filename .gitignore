# Disposable / regenerable artefacts (the entire output/ tree).
output/

# Python build / test caches.
__pycache__/
*.pyc
*.pyo
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.benchmarks/
.mypy_cache/
.ruff_cache/
.venv/
*.egg-info/

# Lake build artefacts.
lean/.lake/
**/.lake/
lean/build/
*.olean
*.ilean
*.ir
*.c

# Editor / OS junk.
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# uv lockfile is project-level and should stay visible for reproducibility.
!uv.lock
