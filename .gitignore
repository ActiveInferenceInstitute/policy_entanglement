lean/.lake/
lean/build/
*.olean
*.ilean
*.ir
*.c

# Editor / OS junk.
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# uv lockfile is project-level, kept; rule out workspace-local copies.
uv.lock
